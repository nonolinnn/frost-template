# ------------------------------------------------------------------
# FROST TSS Wallet — Environment Variables
# Copy to .env and adjust as needed: cp .env.example .env
# ------------------------------------------------------------------

# ---- Solana -------------------------------------------------------
# RPC endpoint used by the coordinator to fetch blockhashes and
# broadcast transactions, and by nodes to derive Solana addresses.
SOLANA_RPC_URL=https://api.devnet.solana.com

# ---- PostgreSQL ---------------------------------------------------
# Credentials for the shared PostgreSQL container.
POSTGRES_USER=frost
POSTGRES_PASSWORD=frost
POSTGRES_DB=frost

# ---- Service Database URLs ----------------------------------------
# Each backend service uses a separate database inside the same
# PostgreSQL instance. The init script creates all three databases.
COORDINATOR_DATABASE_URL=postgresql://frost:frost@postgres:5432/coordinator_db
NODE_A_DATABASE_URL=postgresql://frost:frost@postgres:5432/node_a_db
NODE_B_DATABASE_URL=postgresql://frost:frost@postgres:5432/node_b_db

# ---- Service Ports (host-side) ------------------------------------
# Ports exposed on the Docker host. Internal container ports are fixed.
COORDINATOR_PORT=8080
NODE_A_PORT=8081
NODE_B_PORT=8082
FRONTEND_PORT=3000

# ---- Inter-Service URLs -------------------------------------------
# Used by the coordinator to forward DKG/signing requests to nodes.
# Defaults use Docker Compose service names, which resolve inside the
# Docker network. Only change these for non-Docker setups.
NODE_A_URL=http://node-a:8081
NODE_B_URL=http://node-b:8082

# Used by tss-node services to reach the coordinator (for potential
# callback use). Defaults to the Docker service name.
COORDINATOR_URL=http://coordinator:8080

# ---- Frontend -----------------------------------------------------
# URL the browser uses to reach the coordinator API. Since the browser
# runs outside the Docker network, this must point to the host-mapped
# coordinator port. This value is inlined at Next.js build time.
NEXT_PUBLIC_API_URL=http://localhost:8080
