# ------------------------------------------------------------------
# FROST TSS Wallet — Environment Variables
# Copy to .env and adjust as needed: cp .env.example .env
# ------------------------------------------------------------------

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com

# PostgreSQL
POSTGRES_USER=frost
POSTGRES_PASSWORD=frost
POSTGRES_DB=frost

# Service database URLs (used by each backend service)
COORDINATOR_DATABASE_URL=postgresql://frost:frost@postgres:5432/coordinator_db
NODE_A_DATABASE_URL=postgresql://frost:frost@postgres:5432/node_a_db
NODE_B_DATABASE_URL=postgresql://frost:frost@postgres:5432/node_b_db

# Service ports (host-side)
COORDINATOR_PORT=8080
NODE_A_PORT=8081
NODE_B_PORT=8082
FRONTEND_PORT=3000
